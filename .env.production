# Build de producción (Coolify). Vite carga este archivo en `vite build`.
# Si Coolify define VITE_API_BASE_URL=localhost, apiConfig.js lo ignora en runtime
# y resuelve por hostname; esta variable es respaldo para el bundle.
VITE_API_BASE_URL=https://arnaldbackend.grupoproser.com.co

# VITE_UPLOADS_BASE_URL=https://arnaldbackend.grupoproser.com.co

# Google Maps — definir también en variables de entorno de Coolify al desplegar
# VITE_GOOGLE_MAPS_API_KEY=tu_api_key_de_google_maps
