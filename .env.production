# Build de producción — la URL del API se elige por hostname en apiConfig.js
# (aplicacion → PM2; arnalddataflow / arnald → Coolify). Solo descomenta para forzar un origen:
# VITE_API_BASE_URL=https://arnalddataflowbackend.grupoproser.com.co

# Opcional: otro origen solo para /uploads en dev; si vacío, usa la misma URL del API
# VITE_UPLOADS_BASE_URL=https://arnalddataflowbackend.grupoproser.com.co
