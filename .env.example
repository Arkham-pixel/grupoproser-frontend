# Copiar a .env (desarrollo) o usar en Coolify al desplegar el frontend.
# Solo variables VITE_* se incluyen en el build de Vite.

# URL del backend (sin /api al final)
VITE_API_BASE_URL=http://localhost:3000

# Producción (Coolify) — NO uses localhost aquí; apiConfig resuelve por hostname:
# VITE_API_BASE_URL=https://arnaldbackend.grupoproser.com.co

# Google Maps / Google Earth (MapaGoogleEarth.jsx) — OBLIGATORIO para el mapa
# Obtener clave: https://console.cloud.google.com/google/maps-apis
VITE_GOOGLE_MAPS_API_KEY=AIzaSyAW2ZgTPrhcK68XsICaYGSfF7Fm-b91AMg
# Logs detallados en consola (opcional, false por defecto)
# VITE_DEBUG_LOGS=true
