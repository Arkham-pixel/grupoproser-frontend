# Copiar a .env (desarrollo) o usar en Coolify al desplegar el frontend.
# Solo variables VITE_* se incluyen en el build de Vite.

# Desarrollo local
VITE_API_BASE_URL=http://localhost:3000

# Producción (Coolify — principal 52.20.220.24 y respaldo 18.119.83.81):
# Mismos valores en ambos servidores; DNS apunta al activo.
# VITE_API_BASE_URL=https://arnaldbackend.grupoproser.com.co
# VITE_UPLOADS_BASE_URL=https://arnaldbackend.grupoproser.com.co
# Front público: https://arnald.grupoproser.com.co
# Archivos nuevos van a S3 vía API (STORAGE_DRIVER=s3 en backend); no guardar en disco del servidor.

VITE_GOOGLE_MAPS_API_KEY=
