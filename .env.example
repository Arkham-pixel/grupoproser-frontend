# Copiar a .env (desarrollo) o usar en Coolify al desplegar el frontend.
# Solo variables VITE_* se incluyen en el build de Vite.

# URL del backend (sin /api al final)
VITE_API_BASE_URL=http://localhost:3000

# Producción (Coolify) — NO uses localhost aquí; apiConfig resuelve por hostname:
# VITE_API_BASE_URL=https://arnalddataflowbackend.grupoproser.com.co

VITE_GOOGLE_MAPS_API_KEY=
